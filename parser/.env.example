# Select a provider. Options: ollama | anthropic | gemini
# If PROVIDER is unset, falls back to whichever API key is present.
PROVIDER=ollama

# Required when PROVIDER=anthropic (or unset with only this key present)
ANTHROPIC_API_KEY=

# Required when PROVIDER=gemini (or unset with only this key present)
GEMINI_API_KEY=

# Ollama settings — only used when PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:12b

PORT=4000
ENV=development
